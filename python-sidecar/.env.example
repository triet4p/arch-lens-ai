# Server config
HOST=127.0.0.1
PORT=14201
API_V1_STR=/api/v1
PROJECT_NAME="Arch Lens AI"

# Database
DATABASE_URL="sqlite:///arch_lens.db"

# Logging Config
LOGGING_LEVEL=INFO
LOGGING_HANDLER=both
LOGGING_FILE_DIR=~/.arch_lens/logs

# Storage Config
WORKSPACE_STORAGE_DIR=~/.arch_lens/workspace

# ArXiv API Config
ARXIV_MAX_WAIT_TIME_SECONDS=3.5
ARXIV_HTTP_TIMEOUT_SECONDS=30.0
ARXIV_HTTP_MAX_CONNECTIONS=10
ARXIV_HTTP_MAX_KEEPALIVE_CONNECTIONS=5

# WATCHDOG Config
WATCHDOG_TIMEOUT_SECONDS=45
WATCHDOG_CHECK_INTERVAL_SECONDS=5.0